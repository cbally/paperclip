# External integrations — copy to .env.integrations and fill in your keys
# Never commit .env.integrations (it is git-ignored)

# ─── Odoo CRM ─────────────────────────────────────────────────────────────────
ODOO_URL=https://mycompany.odoo.com
ODOO_DB=mydb
# Preferred: API key (Settings > Technical > API Keys)
ODOO_API_KEY=
# Fallback: username + password
# ODOO_USER=admin
# ODOO_PASSWORD=

# ─── Notion ───────────────────────────────────────────────────────────────────
# Create an integration at https://www.notion.so/my-integrations
NOTION_API_KEY=secret_

# ─── GitHub ───────────────────────────────────────────────────────────────────
# Fine-grained PAT or classic token with repo/issues/actions scopes
GITHUB_TOKEN=ghp_
# Optional: default owner/org for unqualified repo references
GITHUB_DEFAULT_OWNER=

# ─── Clever Cloud ─────────────────────────────────────────────────────────────
# Run `clever login` then find tokens in ~/.config/clever-cloud/clever-tools.json
# Or generate via https://api.clever-cloud.com/v2/self/tokens
CLEVER_TOKEN=
CLEVER_SECRET=
# Optional: default org ID (orga_xxx) — leave empty to use personal account
CLEVER_ORG_ID=
